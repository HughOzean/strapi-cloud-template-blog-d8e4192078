{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Homepage hero and highlighted content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "banner": {
      "type": "component",
      "repeatable": false,
      "component": "shared.homepage-banner"
    },
    "heroBadge": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "text"
    },
    "heroFeatureBoxes": {
      "type": "component",
      "repeatable": true,
      "component": "shared.homepage-feature-box"
    },
    "featuredApps": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::app.app"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
